{
  "name": "@izumisy/pi-file-tree-browser",
  "version": "0.1.0",
  "description": "A pi TUI file browser extension.",
  "scripts": {
    "dev": "pi --no-extensions -e extensions/main.ts",
    "type-check": "tsc -b --noEmit",
    "test": "vitest run"
  },
  "files": [
    "extensions/",
    "skills/",
    "README.md"
  ],
  "keywords": [
    "pi-package"
  ],
  "author": "IzumiSy",
  "license": "MIT",
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.79.6",
    "@earendil-works/pi-tui": "^0.79.6",
    "typebox": "^1.2.16",
    "typescript": "^6.0.3",
    "vitest": "^3.2.4"
  },
  "pi": {
    "extensions": [
      "./extensions/main.ts"
    ],
    "skills": [
      "./skills"
    ]
  },
  "dependencies": {
    "fuzzysort": "^3.1.0"
  }
}
